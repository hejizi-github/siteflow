{
  "name": "siteflow-cli",
  "version": "0.1.0",
  "description": "Reusable site workflows powered by a local browser kernel",
  "license": "MIT",
  "type": "module",
  "bin": {
    "siteflow": "dist/cli/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "docs",
    "examples/receipts",
    "assets/readme"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli/main.js",
    "typecheck": "tsc --noEmit",
    "test:unit": "npm run build && node --test test/unit/**/*.test.mjs",
    "test:coverage": "node scripts/run-unit-coverage.mjs",
    "test:coverage:ci": "SITEFLOW_COVERAGE_LINES=30 SITEFLOW_COVERAGE_BRANCHES=70 SITEFLOW_COVERAGE_FUNCTIONS=35 node scripts/run-unit-coverage.mjs",
    "test:coverage:uncovered": "node scripts/show-unit-coverage-uncovered.mjs",
    "prepack": "npm run build",
    "pack:local": "npm pack",
    "start": "node dist/cli/main.js",
    "smoke:fixture": "npm run build && node test/smoke/fixture-smoke.mjs",
    "smoke:auth-import-browser": "npm run build && node --test test/smoke/auth-import-browser-smoke.mjs",
    "smoke:recorder": "npm run build && node --test test/smoke/workflow-recorder-e2e.mjs"
  },
  "keywords": [
    "browser",
    "automation",
    "playwright",
    "cdp",
    "site-workflows"
  ],
  "dependencies": {
    "commander": "^14.0.2",
    "playwright": "^1.56.1"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
